<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="expo.modules.widgetbuilder"> 
    <application>
        <receiver android:name=".DynamicWidgetReceiver" android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
                <action android:name="com.luminous5972.UPDATE_WIDGET"/>
            </intent-filter>
            <meta-data 
                android:name="android.appwidget.provider" 
                android:resource="@xml/dynamic_widget_info"/>
        </receiver>

        <service
            android:name=".WidgetMessagingService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>
</manifest>